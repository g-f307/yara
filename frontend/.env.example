# Anthropic is kept for compatibility with the planned Claude setup.
# The current local chat route uses Gemini via @ai-sdk/google.
ANTHROPIC_API_KEY=

# Gemini / Google AI SDK
GOOGLE_GENERATIVE_AI_API_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Database
DATABASE_URL=postgresql://yara:yara_password@localhost:5432/yara_db?schema=public

# UploadThing
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# Python Core
# Local host: http://localhost:8000
# Docker Compose: http://backend:8000
PYTHON_CORE_URL=http://localhost:8000
